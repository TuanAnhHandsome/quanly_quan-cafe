{
  "info": {
    "name": "Orders API — Quản lý Quán Cafe",
    "_postman_id": "order-module-v1",
    "description": "Gọi món theo bàn, treo order, thanh toán mới trừ kho",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" }
  ],
  "item": [
    {
      "name": "Orders",
      "item": [
        {
          "name": "GET — Danh sách orders (filter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?tableId=1&status=pending&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "tableId", "value": "1", "description": "Lọc theo bàn" },
                { "key": "status", "value": "pending", "description": "pending | processing | completed | cancelled" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET — Lấy order đang treo của bàn",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?tableId=5&status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "tableId", "value": "5" },
                { "key": "status", "value": "pending" }
              ]
            }
          }
        },
        {
          "name": "GET — Chi tiết order",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/1",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1"]
            }
          }
        },
        {
          "name": "POST — Tạo order mới cho bàn",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tableId\": 5,\n  \"note\": \"Khách VIP\",\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2,\n      \"note\": \"Ít đá\"\n    },\n    {\n      \"productId\": 2,\n      \"quantity\": 1,\n      \"note\": \"Không đường\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "PATCH — Cập nhật items trong order",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": 1,\n  \"note\": \"Thêm món\",\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 3,\n      \"note\": \"Ít đá\"\n    },\n    {\n      \"productId\": 2,\n      \"quantity\": 1,\n      \"note\": \"Không đường\"\n    },\n    {\n      \"productId\": 3,\n      \"quantity\": 2,\n      \"note\": \"\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/1/items",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "items"]
            }
          }
        },
        {
          "name": "POST — Gửi quầy/bar pha chế",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/1/send-to-bar",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "send-to-bar"]
            }
          }
        },
        {
          "name": "POST — Thanh toán order (tiền mặt)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"cash\",\n  \"receivedAmount\": 200000,\n  \"note\": \"Khách đưa tiền mặt\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/1/payment",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "payment"]
            }
          }
        },
        {
          "name": "POST — Thanh toán order (chuyển khoản)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"bank_transfer\",\n  \"note\": \"Chuyển khoản qua VietQR\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/1/payment",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "payment"]
            }
          }
        },
        {
          "name": "POST — Thanh toán QR PayOS",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"payos_qr\",\n  \"note\": \"Khách muốn quét QR\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/1/payment",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "payment"]
            }
          }
        },
        {
          "name": "GET — Polling trạng thái thanh toán QR",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/1/payment-status",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "payment-status"]
            }
          }
        },
        {
          "name": "POST — Hủy QR thanh toán PayOS",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/1/cancel-payment",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "cancel-payment"]
            }
          }
        },
        {
          "name": "PATCH — Hủy order",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/1/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "PayOS Webhook",
      "item": [
        {
          "name": "POST — Webhook callback (simulate)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"00\",\n  \"desc\": \"success\",\n  \"data\": {\n    \"orderCode\": 1001,\n    \"amount\": 150000,\n    \"description\": \"Order #1\",\n    \"accountNumber\": \"123456789\",\n    \"reference\": \"TXN123456\",\n    \"transactionDateTime\": \"2025-01-01 12:00:00\",\n    \"paymentLinkId\": \"abc-def-ghi\",\n    \"code\": \"00\",\n    \"desc\": \"success\",\n    \"counterAccountBankId\": \"\",\n    \"counterAccountBankName\": \"\",\n    \"counterAccountName\": \"\",\n    \"counterAccountNumber\": \"\",\n    \"virtualAccountName\": \"\",\n    \"virtualAccountNumber\": \"\"\n  },\n  \"signature\": \"REPLACE_WITH_VALID_SIGNATURE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "webhook"]
            },
            "description": "Public endpoint — no auth cookie needed. Replace signature with valid HMAC SHA256."
          }
        }
      ]
    },
    {
      "name": "Scenarios — Luồng thực tế",
      "item": [
        {
          "name": "1. Mở bàn 5 — xem order treo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?tableId=5&status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "tableId", "value": "5" },
                { "key": "status", "value": "pending" }
              ]
            }
          }
        },
        {
          "name": "2. Tạo order cho bàn 5",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
