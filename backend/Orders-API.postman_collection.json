            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"version\": 1,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 2, \"note\": \"Ít đá\" },\n    { \"productId\": 2, \"quantity\": 1 },\n    { \"productId\": 3, \"quantity\": 1, \"note\": \"Thêm kem\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/1/items",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "items"]
            }
          }
        },
        {
          "name": "4. Gửi quầy/bar",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/1/send-to-bar",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "send-to-bar"]
            }
          }
        },
        {
          "name": "5. Thanh toán",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"cash\",\n  \"receivedAmount\": 200000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/1/payment",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "1", "payment"]
            }
          }
        }
      ]
    },
