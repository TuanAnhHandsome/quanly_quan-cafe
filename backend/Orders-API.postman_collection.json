            "body": {
              "mode": "raw",
              "raw": "{\n  \"tableId\": 5,\n  \"items\": [\n    { \"productId\": 1, \"quantity\": 2, \"note\": \"Ít đá\" },\n    { \"productId\": 2, \"quantity\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            }
          }
        },
